From: exo-cuda team
Date: Sat Jun 27 2026
Subject: [PATCH 2/2] tinygrad/helpers: handle read-only memoryview in mv_address

ctypes.c_char.from_buffer() raises TypeError on read-only memoryviews.
Add a safety net that copies the memoryview to a writable one before
calling from_buffer.

--- a/tinygrad/helpers.py
+++ b/tinygrad/helpers.py
@@ -525,7 +525,13 @@
 def from_mv(mv:memoryview, to_type:type[ctypes._SimpleCData]=ctypes.c_char) -> ctypes.Array:
   return ctypes.cast(ctypes.addressof(to_type.from_buffer(mv)), ctypes.POINTER(to_type * len(mv))).contents
 def to_mv(ptr:int, sz:int) -> memoryview: return memoryview((ctypes.c_uint8 * sz).from_address(ptr)).cast("B")
-def mv_address(mv): return ctypes.addressof(ctypes.c_char.from_buffer(mv))
+def mv_address(mv):
+  import traceback
+  if mv.readonly:
+    print(f"WARNING: mv_address read-only mv: nbytes={mv.nbytes}, format={mv.format}, ndim={mv.ndim}, shape={mv.shape}")
+    traceback.print_stack(limit=10)
+    mv = mv.copy()
+  return ctypes.addressof(ctypes.c_char.from_buffer(mv))
 def to_char_p_p(options: list[bytes], to_type=ctypes.c_char):
   return (ctypes.POINTER(to_type) * len(options))(*[ctypes.cast(ctypes.create_string_buffer(o), ctypes.POINTER(to_type)) for o in options])
 def flat_mv(mv:memoryview): return mv if len(mv) == 0 else mv.cast("B", shape=(mv.nbytes,))
