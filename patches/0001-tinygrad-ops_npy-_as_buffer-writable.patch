From: exo-cuda team
Date: Sat Jun 27 2026
Subject: [PATCH 1/2] tinygrad/ops_npy: make _as_buffer return writable memoryview

When a numpy array is read-only (e.g. from np.frombuffer), the
memoryview returned by _as_buffer is also read-only, causing
ctypes.c_char.from_buffer(mv) to raise TypeError in mv_address.

Fix: use np.require(src, requirements='CW') to force a writable
copy before creating the memoryview.

--- a/tinygrad/runtime/ops_npy.py
+++ b/tinygrad/runtime/ops_npy.py
@@ -4,7 +4,10 @@
 
 class NpyAllocator(Allocator['NpyDevice']):
   def _alloc(self, size:int, options=None) -> np.ndarray: return np.empty(size, dtype=np.uint8)
-  def _as_buffer(self, src:np.ndarray) -> memoryview: return flat_mv(np.require(src, requirements='C').data)
+  def _as_buffer(self, src:np.ndarray) -> memoryview:
+    if not src.flags.writeable:
+      src = np.require(src, requirements='CW', dtype=src.dtype)
+    return flat_mv(src.data)
   def _copyout(self, dest:memoryview, src:np.ndarray): dest[:] = self._as_buffer(src)
 
 class NpyDevice(Compiled):
